# ──────────────────────────────────────────────────────────
# 미션 포인트 - 소셜 로그인 환경 변수 설정
# ──────────────────────────────────────────────────────────
# 이 파일을 복사하여 .env.local 로 저장하고 값을 입력하세요.
# cp .env.example .env.local

# ── Google OAuth ──────────────────────────────────────────
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
# 승인된 JavaScript 원본에 http://localhost:3000 추가
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Kakao OAuth ───────────────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 설정 → 앱 키 → JavaScript 키
# 플랫폼 → Web → 사이트 도메인에 http://localhost:3000 추가
# Kakao Login → Redirect URI에 http://localhost:3000 추가
VITE_KAKAO_JS_KEY=your-kakao-javascript-key

# ── Naver OAuth ───────────────────────────────────────────
# https://developers.naver.com → Application → 애플리케이션 등록
# 서비스 URL: http://localhost:3000
# Callback URL: http://localhost:3000
VITE_NAVER_CLIENT_ID=your-naver-client-id
VITE_NAVER_CALLBACK_URL=http://localhost:3000
